# Flask Core Configurations (Flask 3.x compliant)
FLASK_APP=app.py
FLASK_DEBUG=1
SECRET_KEY=your_super_secret_key_here_unbreakable

# Database Router (Supports local SQLite or Production PostgreSQL)
DATABASE_URL=sqlite:///knowingcraft.db

# Third-Party API Hardened Endpoints
GEMINI_API_KEY=your_gemini_api_key_here
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name
